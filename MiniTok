let scrollCount = 0;

function trackScrollAd(){

  scrollCount++;

  console.log("Scroll:", scrollCount);

  if(scrollCount % 3 === 0){
    showBannerAd();
  }
}
window.addEventListener("scroll", () => {

  let vh = window.innerHeight;

  if(window.scrollY % vh === 0){
    trackScrollAd();
  }

});
function showBannerAd(){

  let ad = document.createElement("div");

  ad.innerHTML = `
    <div style="
      position:fixed;
      bottom:0;
      left:0;
      width:100%;
      background:white;
      z-index:9999;
      text-align:center;
      padding:10px;
    ">
      <div id="container-68c1976a6a89247b5122edd8438c60f4"></div>
    </div>
  `;

  document.body.appendChild(ad);

  // auto close after 8 sec
  setTimeout(()=>{
    ad.remove();
